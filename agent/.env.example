# ── Required ─────────────────────────────────────────────────────────────────

# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name. Shaul ships on Pro for richer voice and reasoning.
# Set to 'gemini-2.5-flash' if you want faster/cheaper responses.
# NOTE: gemini-2.0-flash and gemini-1.5-* are deprecated — use 2.5 variants.
GEMINI_MODEL=gemini-2.5-pro

# GreenInvoice API credentials
GREENINVOICE_API_ID=your_api_id_here
GREENINVOICE_API_SECRET=your_api_secret_here

# Absolute path to the compiled GreenInvoice MCP server (dist/index.js)
# Windows example:
#   MCP_SERVER_PATH=C:\Users\User\Documents\morningMCP\GreenInvoice-MCP-main\dist\index.js
# Android/Linux example:
#   MCP_SERVER_PATH=/home/user/GreenInvoice-MCP-main/dist/index.js
MCP_SERVER_PATH=

# ── Optional ──────────────────────────────────────────────────────────────────

# Enable WhatsApp listener (set to 'true' to activate)
ENABLE_WHATSAPP=true

# Your WhatsApp phone number in international format without + (e.g. 972545684800)
# When set, shows a pairing code on first login instead of a QR code.
# Leave empty to use QR code instead.
WHATSAPP_PHONE=

# Path to Node.js executable used to launch the MCP server.
# Leave unset (or set to 'node') to use whatever 'node' is on PATH.
# Only needed if you want to use a specific Node.js binary.
# Windows example:
#   NODE_EXECUTABLE=C:\Users\User\Documents\morningMCP\node\node-v20.12.2-win-x64\node.exe
# Android/Linux: leave unset — system 'node' is used automatically
#NODE_EXECUTABLE=node

# Path to Chrome/Chromium for Puppeteer (WhatsApp Web).
# Leave unset to use Puppeteer's bundled Chromium.
# Windows example:
#   CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# Android Termux example:
#   CHROME_EXECUTABLE_PATH=/data/data/com.termux/files/usr/bin/chromium-browser
#CHROME_EXECUTABLE_PATH=

# ── Notion (note command) ─────────────────────────────────────────────────────

# Notion integration API key (from https://www.notion.so/my-integrations)
# Required for the 'note' command. Leave empty to disable note commands.
#NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database ID for storing notes/ideas
# Find it in the database URL: notion.so/workspace/<DATABASE_ID>?v=...
#NOTION_NOTES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail credentials for the email agent (optional)
#EMAIL_USER=your_email@gmail.com
#EMAIL_PASSWORD=your_app_password_here

# ── Phase 2: Marketing department ────────────────────────────────────────────

# SQLite DB file for Shaul's long-term memory.
# Default: agent/data/shaul-memory.db (created automatically on first message).
#SHAUL_DB_PATH=/path/to/shaul-memory.db

# Meta (Facebook + Instagram) credentials. Required for the Publisher sub-agent
# to actually post. Without these, Shaul still drafts campaigns and creatives
# but won't publish — drafts are saved for later.
#
# How to get them:
#   1. Meta Business account: https://business.facebook.com
#   2. Meta for Developers → create a Business-type App
#   3. Connect a Facebook Page + an Instagram Business account
#   4. Generate a long-lived Page Access Token (60-day TTL — re-issue when expired)
#      Permissions required: pages_manage_posts, pages_read_engagement,
#                            instagram_basic, instagram_content_publish
#
#META_PAGE_ID=123456789012345
#META_PAGE_TOKEN=EAAG...long_lived_page_token...
#IG_BUSINESS_ID=178414...

# Optional: ad-account for paid-campaign insights (format: act_XXXXX)
#META_AD_ACCOUNT_ID=act_1234567890

# Phase 3: local hour for proactive daily briefing (24h, default 8 = 08:00).
#SHAUL_BRIEFING_HOUR=8

# ── Phase 4: privacy, calendar, canva ────────────────────────────────────────

# Inbound allow-list. Comma-separated phone numbers (any format). When set,
# Shaul ignores messages from anyone NOT on this list. Empty = accept everyone.
# Example: SHAUL_ALLOWED_NUMBERS=0527203222,0546736909
#SHAUL_ALLOWED_NUMBERS=

# Google Calendar MCP server (any community-built one is fine — point this at
# its compiled entry point). The agent uses it for "what's on my calendar
# today", "schedule a follow-up with X", "create event Y at time Z".
# How to set up:
#   1. Pick a Google Calendar MCP server (e.g. nspady/google-calendar-mcp)
#   2. Run its OAuth flow per its README, save the refresh token wherever it
#      expects (commonly a JSON file or env var)
#   3. Set CALENDAR_MCP_PATH to its dist entry point
#CALENDAR_MCP_PATH=/abs/path/to/google-calendar-mcp/dist/index.js
#GOOGLE_CALENDAR_CREDENTIALS=/abs/path/to/credentials.json
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GOOGLE_REFRESH_TOKEN=

# Optional: Canva MCP path if a public one ships. Until then, we use Canva
# Connect REST directly (configure CANVA_CLIENT_ID / CANVA_CLIENT_SECRET /
# CANVA_REFRESH_TOKEN below).
#CANVA_MCP_PATH=

# Optional: Meta MCP path. Until a public one ships, we use the Graph API
# directly via the META_PAGE_TOKEN above.
#META_MCP_PATH=

# Canva Connect API. Get client_id + client_secret from
# https://www.canva.com/developers/ and run:
#   node agent/scripts/canva-oauth.js
# to obtain the refresh token.
#CANVA_CLIENT_ID=
#CANVA_CLIENT_SECRET=
#CANVA_REFRESH_TOKEN=
#CANVA_REDIRECT_URI=http://localhost:5234/canva-callback
